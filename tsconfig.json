{
  "compilerOptions": {
    "module": "commonjs",                    // Changed from "nodenext"
    "moduleResolution": "node10",             // Changed from "nodenext"
    "resolvePackageJsonExports": false,       // Changed to false
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",                        // Changed from ES2023 for better compatibility
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/*": ["./src/*"]                       // Add path alias
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}